.notification-bell-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    width: 36px;
    height: 36px;
    border-radius: var(--border-radius-base);
    transition: all 0.2s ease;
    color: #FFFFFF;
}

.notification-bell-container:hover {
    background: #1a1a1a;
}

.notification-badge {
    position: absolute;
    top: -2px;
    right: -2px;
    background: var(--primary);
    color: var(--bg-primary);
    font-size: 0.7rem;
    font-weight: 800;
    min-width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    border: 2px solid #000000;
    z-index: 2;
    animation: badge-pop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes badge-pop {
    from {
        transform: scale(0);
    }

    to {
        transform: scale(1);
    }
}

.notification-panel {
    position: absolute;
    top: calc(100% + 10px);
    right: -10px;
    width: 320px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-xl);
    z-index: var(--z-dropdown);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform-origin: top right;
    animation: panel-pop 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes panel-pop {
    from {
        opacity: 0;
        transform: scale(0.95) translateY(-10px);
    }

    to {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
}

.panel-header {
    padding: var(--spacing-4);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--bg-tertiary);
}

.panel-header h4 {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.panel-actions {
    display: flex;
    gap: var(--spacing-2);
}

.panel-btn {
    background: none;
    border: none;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-muted);
    cursor: pointer;
    text-transform: uppercase;
    transition: color 0.2s;
}

.panel-btn:hover {
    color: var(--text-primary);
}

.notification-list {
    max-height: 400px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
}

.notification-item {
    padding: var(--spacing-4);
    display: flex;
    gap: var(--spacing-3);
    border-bottom: 1px solid var(--border-subtle);
    transition: background-color 0.2s;
    cursor: pointer;
    position: relative;
}

.notification-item:hover {
    background: var(--bg-tertiary);
}

.notification-item.unread {
    background: rgba(0, 0, 0, 0.03);
}

[data-theme='dark'] .notification-item.unread {
    background: rgba(255, 255, 255, 0.03);
}

.notification-item.unread::before {
    content: '';
    position: absolute;
    left: 4px;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 4px;
    background: var(--primary);
    border-radius: 50%;
}

.notification-item-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.icon-success {
    background: rgba(0, 255, 0, 0.1);
    color: var(--success);
}

.icon-error {
    background: rgba(255, 0, 0, 0.1);
    color: var(--error);
}

.icon-warning {
    background: rgba(251, 191, 36, 0.1);
    color: var(--warning);
}

.icon-info {
    background: rgba(0, 0, 0, 0.1);
    color: var(--text-primary);
}

.notification-item-content {
    flex: 1;
    min-width: 0;
}

.notification-item-message {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 2px;
    word-break: break-word;
}

.notification-item-time {
    font-size: 0.75rem;
    color: var(--text-muted);
}

.empty-state {
    padding: var(--spacing-8);
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
}
